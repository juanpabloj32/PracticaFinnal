<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="25dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Tiendita"
                    android:textSize="31sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registra un nuevo producto al sistema"
                    android:textSize="15sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="5dp"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/iconoAgregar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/t"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="6dp"/>

        </RelativeLayout>

        <ImageView
            android:id="@+id/imagenProducto"
            android:layout_width="190dp"
            android:layout_height="190dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#FFFFFF"
            android:padding="6dp"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:elevation="5dp"/>

        <Button
            android:id="@+id/seleccionarImagen"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SELECCIONAR IMAGEN"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#334155"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="22dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="26dp"
            android:elevation="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del producto"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/nombre"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:hint="Ejemplo: Laptop Gamer"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111827"
                android:textColorHint="#94A3B8"
                android:background="#F8FAFC"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:layout_marginTop="22dp"/>

            <EditText
                android:id="@+id/descripcion"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Describe el producto"
                android:gravity="top"
                android:padding="18dp"
                android:textColor="#111827"
                android:textColorHint="#94A3B8"
                android:background="#F8FAFC"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precio"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:layout_marginTop="22dp"/>

            <EditText
                android:id="@+id/precio"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:hint="Ejemplo: 15000"
                android:inputType="numberDecimal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111827"
                android:textColorHint="#94A3B8"
                android:background="#F8FAFC"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:layout_marginTop="22dp"/>

            <EditText
                android:id="@+id/stock"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:hint="Cantidad disponible"
                android:inputType="number"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#111827"
                android:textColorHint="#94A3B8"
                android:background="#F8FAFC"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/guardar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="GUARDAR PRODUCTO"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB"
                android:layout_marginTop="32dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>